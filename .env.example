# Copy this file to .env and fill in your own values. .env is gitignored -
# never commit your real API key or personal details.
#
# Every setting here has a sensible default baked into app/config.py, so you
# only need to set what's listed below to get running. For the full list of
# ~50 tunable knobs (denoise strengths, per-worker daily image counts, collage
# sizing, then-and-now gap/quality thresholds, etc.) read app/config.py
# directly - each one is documented inline next to its default.

# --- Required ---

# Your Immich server's base URL and an API key (Immich web UI -> Account
# Settings -> API Keys).
AIENH_IMMICH_URL=http://localhost:2283
AIENH_IMMICH_API_KEY=

# Comma-separated list of names exactly as you've tagged them in Immich's
# People view. Every worker only ever touches photos of these people.
AIENH_TARGET_PEOPLE=Alice Smith,Bob Smith

# Host running Ollama (vision-language model calls) and ComfyUI (SDXL/upscale/
# face-restore workflows). If both run on the same box, AIENH_MAC_HOST alone
# is enough; otherwise override AIENH_OLLAMA_URL / AIENH_COMFYUI_URL directly.
AIENH_MAC_HOST=localhost
# AIENH_OLLAMA_URL=http://localhost:11434
# AIENH_COMFYUI_URL=http://localhost:8188

# --- Commonly tuned ---

# Vision-language model Ollama uses for style/filter/prompt selection and
# mood-emoji picks. Must already be pulled on the Ollama host (ollama pull ...).
AIENH_OLLAMA_VISION_MODEL=qwen3-vl:8b

# Album each worker uploads its output into (created automatically if missing).
AIENH_IMMICH_ALBUM_NAME=AI
AIENH_DESIGN_IMMICH_ALBUM_NAME=AI Designed
AIENH_FILTER_IMMICH_ALBUM_NAME=AI Filtered
AIENH_COLLAGE_IMMICH_ALBUM_NAME=AI Collages
AIENH_CARTOON_IMMICH_ALBUM_NAME=AI Cartoon

# How many photos each worker processes per run (a cron job typically calls
# each worker's `python -m app.<worker>` once a day - see README "Automation").
AIENH_IMAGES_PER_DAY=2
AIENH_DESIGN_IMAGES_PER_DAY=2
AIENH_FILTER_IMAGES_PER_DAY=2
AIENH_CARTOON_IMAGES_PER_DAY=1

# Where generated output PNGs are written before upload.
AIENH_OUTPUT_DIR=./output
